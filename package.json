{
  "name": "@paulrobins/wafermap",
  "version": "0.4.0",
  "description": "Browser-first wafer map visualization toolkit with a renderer abstraction and Plotly adapter.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/packages/core/index.d.ts",
      "import": "./dist/packages/core/index.js"
    },
    "./renderer": {
      "types": "./dist/packages/renderer/index.d.ts",
      "import": "./dist/packages/renderer/index.js"
    },
    "./plotly-adapter": {
      "types": "./dist/packages/plotly-adapter/index.d.ts",
      "import": "./dist/packages/plotly-adapter/index.js"
    },
    "./worker": {
      "types": "./dist/packages/worker/index.d.ts",
      "import": "./dist/packages/worker/index.js"
    },
    "./worker-script": {
      "types": "./dist/packages/worker/wafermap.worker.d.ts",
      "import": "./dist/packages/worker/wafermap.worker.js"
    },
    "./canvas-adapter": {
      "types": "./dist/packages/canvas-adapter/index.d.ts",
      "import": "./dist/packages/canvas-adapter/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "wafer",
    "wafer-map",
    "plotly",
    "semiconductor",
    "visualization"
  ],
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}

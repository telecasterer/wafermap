{
  "name": "wmap",
  "version": "0.1.0",
  "description": "Browser-first wafer map visualization toolkit with a renderer abstraction and Plotly adapter.",
  "type": "module",
  "private": true,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/packages/core/index.d.ts",
      "import": "./dist/packages/core/index.js"
    },
    "./renderer": {
      "types": "./dist/packages/renderer/index.d.ts",
      "import": "./dist/packages/renderer/index.js"
    },
    "./plotly-adapter": {
      "types": "./dist/packages/plotly-adapter/index.d.ts",
      "import": "./dist/packages/plotly-adapter/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "keywords": [
    "wafer",
    "wafer-map",
    "plotly",
    "semiconductor",
    "visualization"
  ],
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
